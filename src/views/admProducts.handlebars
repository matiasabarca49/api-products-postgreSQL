<link rel="stylesheet" href="../css/style.css">
<header>
    <nav class="navbar">
        <div class="nav-brand">
          <a class="brand-link" href="http://localhost:8080/admin">Panel</a>
        </div>
        <div class="nav-actions">
            <div class="user-name">{{userLoged.user}}</div>
            {{#if userLoged.user}}
                <div>
                    <a class="btn btn-light" href="/users/perfil">Ver Perfil</a>
                </div>
                <div>
                    <a class="btn btn-danger" href="/api/sessions/logout">salir</a> 
                </div>
            {{/if}}
            {{#unless userLoged.user}}
                <div>
                    <a class="btn btn-light" href="/users/login">Iniciar Sesión</a>
                </div>
            {{/unless}}
            {{#if userLoged.user}}
                {{#ifCond userLoged.rol "admin"}}
                    <div>
                        <a class="btn icon-btn" href="/admin"><img class="nav-icon" src="../img/configurar.png" alt="home"></a>
                    </div>
                {{/ifCond}}
            {{/if}}
        </div>
    </nav>
</header>
<main class="main-container">
    {{#if userLoged.user}}
        {{#ifCond userLoged.rol "premium"}}
            <div>
                <a class="back-button" href="/"> Regresar </a>                    
            </div>
        {{else}} 
            <div>
                <a class="back-button" href="/admin"> Regresar </a> 
            </div>
        {{/ifCond}}
    {{/if}}
    <div class="welcome-text">
        Administración de Productos
    </div>
    <div class="products-header-adm">
    <h2 class="products-title-adm">Productos:</h2>
    <div class="filter-controls">
        <div class="search-container">
            <input type="text"  class="search-input" placeholder="Buscar productos..." id="searchInput">
            <input type="button" value="Buscar" class="filter-btn" id="searchInputButton">
        </div>
        
        <div class="filter-group">
            <label for="categoryFilter">Categoría:</label>
            <select id="categoryFilter" class="filter-select">
                <option value="">Todas</option>
                <option value="ropa">Ropa</option>
                <option value="tecnología">Tecnología</option>
                <option value="bazar">Bazar</option>
                <option value="calzado">Calzado</option>
            </select>
        </div>
        
        <div class="filter-group">
            <label for="sortFilter">Ordenar:</label>
            <select id="sortFilter" class="filter-select">
                <option value="1">Precio Ascendente</option>
                <option value="-1">Precio Descendente</option>
            </select>
        </div>
        
        <div class="filter-group">
            <label for="itemsPerPage">Productos por página:</label>
            <select id="itemsPerPage" class="filter-select items-select">
                <option value="1">1</option>
                <option value="3">3</option>
                <option selected value="6" >6</option>
                <option value="12">12</option>
                <option value="24">24</option>
                <option value="48">48</option>
            </select>
        </div>
        <a class="btn btn-success add-product-btn" id="addProduct">
            <span>+</span> Agregar producto
        </a>
    </div>
</div>
    <div class="products-grid" id="products">

    </div>
    <div class="pagination-container">
        <ul class="pagination">
            <li class="page-item">
                <div class="page-btn" id="prevPag">prev</div>
            </li>
            
            <li class="page-item"><a class="page-link" id="currtPag"></a></li>
            <li class="page-item">
            <div class="page-btn" id="nextPag">next</div>
            </li>
        </ul>
    </div>
    <div id="ProductModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="modalTitle">Editar Producto</h2>
                <span class="close-modal">&times;</span>
            </div>
            <div class="modal-body">
                <form id="ProductForm">
                    <div class="form-group">
                        <label for="Title">Título</label>
                        <input type="text" id="titleId" name="title" required>
                    </div>

                    <div class="form-group">
                        <label for="categoryId" required>Categoría</label>
                        <select id="categoryId" name="category">
                            <option value="bazar">Bazar</option>
                            <option value="ropa">Ropa</option>
                            <option value="tecnología">Tecnología</option>
                            <option value="calzado">Calzado</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="code">Code</label>
                        <input type="text" id="codeId" name="code" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="Price">Precio</label>
                        <input type="number" id="priceId" name="price" step="0.01" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="Description">Descripción</label>
                        <textarea id="descriptionId" name="description" rows="4"></textarea>
                    </div>
                    
                    <div class="form-group">
                        <label for="editStock">Stock</label>
                        <input type="number" id="stockId" name="stock" min="0" required>
                    </div>

                    <div class="form-group">
                        <label for="thumbnailId">Thumbnail</label>
                        <input type="text" id="thumbnailId" name="thumbnail" required>
                    </div>

                    <div class="form-group">
                        <label for="statusId">Status</label>
                        <select id="statusId" name="status">
                            <option value="false">false</option>
                            <option value="true">true</option>
                        </select>
                    </div>
                    
                    <div class="modal-actions">
                        <button type="button" class="btn btn-danger cancel-btn">Cancelar</button>
                        <button type="submit" class="btn btn-success save-btn" >Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
</div>
</main>
<script src="../../js/managerProducts.js"></script>