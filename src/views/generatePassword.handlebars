<div style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <div class="block-component" style="width: 100%; max-width: 420px; padding: 2.5rem; margin: 2rem;">

        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="width: 64px; height: 64px; background: linear-gradient(45deg, #2a5298, #1e3c72); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.2rem; box-shadow: 0 8px 20px rgba(42,82,152,0.4);">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
            </div>
            <h1 style="color: white; font-size: 1.8rem; font-weight: bold; text-shadow: 0 2px 10px rgba(0,0,0,0.3); margin-bottom: 0.6rem;">
                Cambio de contraseña
            </h1>
            <p style="color: rgba(255,255,255,0.7); font-size: 0.95rem; line-height: 1.5; margin: 0;">
                Ingresá tu nueva contraseña para recuperar el acceso.
            </p>
        </div>

        <form action="/api/sessions/changepassword" method="post" id="formID">
            <div style="margin-bottom: 1.5rem;">
                <label for="password" style="display: block; color: rgba(255,255,255,0.85); font-size: 0.9rem; font-weight: 500; margin-bottom: 0.5rem;">
                    Nueva contraseña
                </label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    required
                    placeholder="••••••••"
                    style="
                        width: 100%;
                        padding: 0.85rem 1rem;
                        border: 1px solid rgba(255,255,255,0.3);
                        border-radius: 15px;
                        background: rgba(255,255,255,0.1);
                        backdrop-filter: blur(10px);
                        color: white;
                        font-size: 1rem;
                        box-sizing: border-box;
                        transition: all 0.3s ease;
                        outline: none;
                    "
                    onfocus="this.style.borderColor='rgba(255,255,255,0.55)'; this.style.background='rgba(255,255,255,0.15)'; this.style.boxShadow='0 0 20px rgba(255,255,255,0.1)'"
                    onblur="this.style.borderColor='rgba(255,255,255,0.3)'; this.style.background='rgba(255,255,255,0.1)'; this.style.boxShadow='none'"
                >
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label for="confirmPassword" style="display: block; color: rgba(255,255,255,0.85); font-size: 0.9rem; font-weight: 500; margin-bottom: 0.5rem;">
                    Confirmar contraseña
                </label>
                <input
                    type="password"
                    id="confirmPassword"
                    placeholder="••••••••"
                    style="
                        width: 100%;
                        padding: 0.85rem 1rem;
                        border: 1px solid rgba(255,255,255,0.3);
                        border-radius: 15px;
                        background: rgba(255,255,255,0.1);
                        backdrop-filter: blur(10px);
                        color: white;
                        font-size: 1rem;
                        box-sizing: border-box;
                        transition: all 0.3s ease;
                        outline: none;
                    "
                    onfocus="this.style.borderColor='rgba(255,255,255,0.55)'; this.style.background='rgba(255,255,255,0.15)'; this.style.boxShadow='0 0 20px rgba(255,255,255,0.1)'"
                    onblur="this.style.borderColor='rgba(255,255,255,0.3)'; this.style.background='rgba(255,255,255,0.1)'; this.style.boxShadow='none'"
                >
                <p id="matchError" style="display: none; color: #ff6b6b; font-size: 0.85rem; margin-top: 0.4rem;">
                    Las contraseñas no coinciden.
                </p>
            </div>

            <button
                type="submit"
                class="btn btn-light"
                style="width: 100%; padding: 0.85rem; font-size: 1rem; border-radius: 15px; text-align: center;"
            >
                Cambiar contraseña
            </button>
        </form>

        <div id="successMsg" style="display: none; text-align: center; margin-top: 1.5rem;">
            <div style="background: rgba(40,167,69,0.2); border: 1px solid rgba(40,167,69,0.4); border-radius: 15px; padding: 1rem;">
                <p style="color: rgba(255,255,255,0.9); font-size: 0.95rem; margin: 0;">
                    ✓ Contraseña actualizada correctamente.
                </p>
            </div>
        </div>

        <div style="text-align: center; margin-top: 1.5rem;">
            <a href="../users/login" style="color: rgba(255,255,255,0.6); font-size: 0.9rem; text-decoration: none; transition: color 0.3s ease;"
               onmouseover="this.style.color='rgba(255,255,255,0.9)'"
               onmouseout="this.style.color='rgba(255,255,255,0.6)'">
                ← Volver al inicio de sesión
            </a>
        </div>

    </div>
</div>

<script>
    const url = window.location.search
const params = new URLSearchParams(url)
const email = params.get("email")
const secret = params.get("secret")
const form = document.getElementById('formID')

form.setAttribute('action', `/api/sessions/changepassword?secret=${secret}&email=${email}`)

form.addEventListener('submit', function(e) {
    const password = document.getElementById('password').value
    const confirm = document.getElementById('confirmPassword').value
    const matchError = document.getElementById('matchError')

    if (password !== confirm) {
        e.preventDefault()
        matchError.style.display = 'block'
        return
    }

    matchError.style.display = 'none'
})
</script>