<link rel="stylesheet" href="../../css/style.css">
<header>
    <nav class="navbar">
        <div class="nav-brand">
          <a class="brand-link" href="http://localhost:8080/">Tienda</a>
        </div>
        <div class="nav-actions">
            <div class="user-name">{{userLoged.user}}</div>
            {{#if userLoged.user}}
                <div>
                    <a class="btn btn-danger" href="/api/sessions/logout">salir</a> 
                </div>
            {{/if}}
            {{#unless userLoged.user}}
                <div>
                    <a class="btn btn-light" href="/users/login">Iniciar Sesión</a>
                </div>
            {{/unless}}
            {{#ifCond userLoged.rol "admin"}}
                <div>
                    <a class="btn icon-btn" href="/admin"><img class="nav-icon" src="../../img/configurar.png" alt="home"></a>
                </div>
            {{else}}
                <div>
                    <a class="btn icon-btn" href="../chat"><img class="nav-icon" src="../../img/chat.png" alt="home"></a>
                </div>
            {{/ifCond}}
            {{#ifCond userLoged.rol "premium"}}
                <div>
                    <a class="btn icon-btn" href="/realtimeproducts"><img class="nav-icon" src="../../img/upload.png" alt="home"></a>
                </div>
            {{/ifCond}}
        </div>
    </nav>
</header>
<div class="mx-5 mt-5">
    <a class="back-button" href="/"> Regresar </a>
    <div class="profile-container">
        <h1 class="profile-main-title">Datos del Perfil:</h1>
        <div class="profile-card">
            <div class="profile-field">
                <span class="profile-label">Nombre:</span>
                <span class="profile-value">{{userLoged.user}}</span>
            </div>
            <div class="profile-field">
                <span class="profile-label">Apellido:</span>
                <span class="profile-value">{{userLoged.last_name}}</span>
            </div>
            <div class="profile-field">
                <span class="profile-label">Edad:</span>
                <span class="profile-value">{{userLoged.age}}</span>
            </div>
            <div class="profile-field">
                <span class="profile-label">Email:</span>
                <span class="profile-value">{{userLoged.email}}</span>
            </div>
            <div class="profile-field">
                <span class="profile-label">Permisos a nivel de:</span>
                <span class="profile-value profile-role">{{userLoged.rol}}</span>
            </div>
        </div>
    </div>

{{!-- UPGRADE A PREMIUM --}}
{{#ifCond userLoged.rol "user"}}
<div style="display:flex; justify-content:center; margin: 2rem 0 1rem;">
    <a href="" class="btn btn-danger"
    onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 10px 35px rgba(247,151,30,0.6)'"
    onmouseout="this.style.transform='';this.style.boxShadow='0 6px 25px rgba(247,151,30,0.45)'">
        Subir a Premium
    </a>
</div>
{{/ifCond}}

{{!-- SECCIÓN DE DIRECCIONES --}}
<div class="purchase-history-container" style="margin-top:2.5rem;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem; flex-wrap:wrap; gap:1rem;">
        <h3 class="purchase-history-title" style="margin:0;">Mis Direcciones:</h3>
        <button id="btnNewAddress" class="save-btn" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.65rem 1.4rem;border-radius:25px;">
            + Agregar dirección
        </button>
    </div>
    <div id="addressList">
        {{!-- Se carga con JS --}}
    </div>
</div>

{{!-- SECCION COMPRAS --}}
<div class="purchase-history-container">
    <h3 class="purchase-history-title">Historial de compras:</h3>
    <div id="compras">
        {{!-- Aca van las compras --}}
    </div>
</div>
</div>
<script src="../js/profile.js" ></script>