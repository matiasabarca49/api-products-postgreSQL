<link rel="stylesheet" href="../css/style.css">
<header>
    <nav class="navbar">
        <div class="nav-brand">
          <a class="brand-link" href="http://localhost:8080/">Tienda</a>
        </div>
        <div class="nav-actions">
            <div class="user-name">{{userLoged.user}}</div>
            {{#if userLoged.user}}
                <div>
                    <a class="btn btn-light" href="/users/perfil">Ver Perfil</a>
                </div>
                <div>
                    <a class="btn btn-danger" href="/api/sessions/logout">salir</a> 
                </div>
            {{/if}}
            {{#unless userLoged.user}}
                <div>
                    <a class="btn btn-light" href="/users/login">Iniciar Sesión</a>
                </div>
            {{/unless}}
            {{#if userLoged.user}}
                {{#ifCond userLoged.rol "admin"}}
                    <div>
                        <a class="btn icon-btn" href="/admin"><img class="nav-icon" src="../../img/configurar.png" alt="home"></a>
                    </div>
                {{else}}
                    <div>
                        <a class="btn icon-btn" href="../chat"><img class="nav-icon" src="../../img/chat.png" alt="home"></a>
                    </div>
                {{/ifCond}}
            {{/if}}
            {{#ifCond userLoged.rol "premium"}}
                <div>
                    <a class="btn icon-btn" href="/admin/products"><img class="nav-icon" src="../../img/upload.png" alt="home"></a>
                </div>
            {{/ifCond}}
        </div>
        <div class="cart-container">
            <a href="http://localhost:8080/pay" class="cart-btn">
                <img class="cart-icon" src="../img/cart.png" />
                <span class="cart-badge" id="totalCountNav">
                    
                </span>
            </a>
        </div>
    </nav>
</header>
<div></div>
<main class="container-fluid mt-5 position-relative">
    <div class="p-4 bg-danger w-50 position-absolute top-0 start-50 translate-middle rounded shadow" style="display: none; z-index: 999;"id="modalWarningRolUser">  </div>
    <a class="back-button" href="http://localhost:8080/"> Regresar </a>
    <div class="row px-5">
        <div  class="col-6 position-relative" id="thumbnail">
            <h4 class="position-absolute text-body-tertiary mt-3 ms-3 p-2 bg-opacity-25 bg-body-tertiary rounded-5 shadow-lg" id="category"></h4>
            <img src="../img/image.jpg" class="img-thumbnail" alt="...">
        </div>
        <div class="col-6 product-card">
            <div class="card-body">
                <h1 id="title" class="card-title my-3 fs-3"></h1>
                <h2 id="price"class="card-price"></h2>
                <p id="description" class="card_description"></p>
                <h5 class="card_stock my-4" id="stock"></h5>
                <button class="btn btn-success" id="addCart">Agregar al carrito</button>
            </div>
        </div>
    </div>
    <section class="main-container" style="max-width:1200px; padding: 0 2rem 2rem;">

    <!-- Vendedor -->
    <div class="block-component" style="padding:2rem; margin-bottom:1.5rem;">
        <h2 style="color:white; font-size:1.4rem; font-weight:bold; margin-bottom:1.2rem; text-shadow:0 2px 10px rgba(0,0,0,0.3);">Vendedor</h2>
        <div style="display:flex; align-items:center; gap:1rem;">
        <div style="width:52px; height:52px; border-radius:50%; background:linear-gradient(45deg,#2a5298,#1e3c72); display:flex; align-items:center; justify-content:center; font-size:1.4rem; font-weight:bold; color:white; flex-shrink:0; border:2px solid rgba(255,255,255,0.3);" id="sellerInitial"></div>
        <div style="flex:1;">
            <div style="font-size:1.2rem; font-weight:bold; color:white;" id="sellerName"></div>
            <div style="font-size:0.85rem; color:rgba(255,255,255,0.65);">Vendedor verificado</div>
        </div>
        <span style="background:linear-gradient(45deg,#28a745,#20c997); color:white; padding:0.35rem 1rem; border-radius:20px; font-size:0.85rem; font-weight:600;">✓ Verificado</span>
        </div>
        <hr style="border:none; border-top:1px solid rgba(255,255,255,0.12); margin:1.2rem 0;">
        <hr style="border:none; border-top:1px solid rgba(255,255,255,0.12); margin:1.2rem 0;">
        <div style="color:rgba(255,255,255,0.55); font-size:0.9rem; margin-bottom:0.75rem;">
            Otros vendedores
        </div>
        <div id="otherSellersContainer"></div>
    </div>

    <!-- Comentarios -->
    <div class="block-component" style="padding:2rem;">
        <h2 style="color:white; font-size:1.4rem; font-weight:bold; margin-bottom:1.2rem; text-shadow:0 2px 10px rgba(0,0,0,0.3);">Comentarios</h2>
        <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem;">
        <div>
            <div style="font-size:2.8rem; font-weight:bold; color:white; line-height:1;" id="avgRating">—</div>
            <div style="color:rgba(255,255,255,0.65); font-size:0.85rem; margin-top:4px;">Promedio</div>
        </div>
        <div id="avgStars" style="display:flex; gap:4px;"></div>
        </div>
        <div id="commentsContainer"></div>
    </div>

    </section>
</main>
<script src="../js/cart.js"></script>
<script src="../js/productview.js"></script>