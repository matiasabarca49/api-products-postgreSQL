<link rel="stylesheet" href="../../css/style.css">
</head>
<header>
    <nav class="navbar">
        <div class="nav-brand">
          <a class="brand-link" href="http://localhost:8080/admin">Panel</a>
        </div>
        <div class="nav-actions">
            <div class="user-name">{{userLoged.user}}</div>
            {{#if userLoged.user}}
                <div>
                    <a class="btn btn-light" href="/users/perfil">Ver Perfil</a>
                </div>
                <div>
                        <a class="btn btn-light" href="/">Tienda</a>
                </div>
                <div>
                    <a class="btn btn-danger" href="/api/sessions/logout">salir</a> 
                </div>
            {{/if}}
            {{#unless userLoged.user}}
                <div>
                    <a class="btn btn-light" href="/users/login">Iniciar Sesión</a>
                </div>
            {{/unless}}
        </div>
    </nav>
</header>
<body>
    <div class="main-container">
        {{#if userLoged.user}}
        {{#ifCond userLoged.rol "premium"}}
            <div>
                <a class="back-button" href="/"> Regresar </a>                    
            </div>
        {{else}} 
            <div>
                <a class="back-button" href="/admin"> Regresar </a> 
            </div>
        {{/ifCond}}
    {{/if}}
        <h1 class="first-text">Ventas</h1>

       
        <!-- Stats bar -->
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-bottom:2rem;">
            <div class="block-component" style="padding:1.5rem;text-align:center;">
                <p style="color:rgba(255,255,255,0.7);font-size:0.9rem;margin-bottom:0.5rem;text-transform:uppercase;letter-spacing:0.5px;">Total Recaudado</p>
                <p id="statTotal" style="font-size:2rem;font-weight:bold;color:white;text-shadow:0 2px 10px rgba(0,0,0,0.3);">-</p>
            </div>
            <div class="block-component" style="padding:1.5rem;text-align:center;">
                <p style="color:rgba(255,255,255,0.7);font-size:0.9rem;margin-bottom:0.5rem;text-transform:uppercase;letter-spacing:0.5px;">Total Órdenes</p>
                <p id="statOrders" style="font-size:2rem;font-weight:bold;color:white;text-shadow:0 2px 10px rgba(0,0,0,0.3);">-</p>
            </div>
            <div class="block-component" style="padding:1.5rem;text-align:center;">
                <p style="color:rgba(255,255,255,0.7);font-size:0.9rem;margin-bottom:0.5rem;text-transform:uppercase;letter-spacing:0.5px;">Promedio por Orden</p>
                <p id="statAvg" style="font-size:2rem;font-weight:bold;color:white;text-shadow:0 2px 10px rgba(0,0,0,0.3);">-</p>
            </div>
        </div>

        <!-- Filtros -->
        <div class="products-header-adm">
            <h2 class="products-title-adm">Historial de Ventas</h2>
            <div class="filter-controls" style="grid-template-columns:2fr 1fr 1fr 1fr auto;">
                <div class="search-container">
                    <input
                        type="text"
                        id="searchInput"
                        class="search-input"
                        placeholder="Buscar por nombre, email o DNI..."
                    />
                </div>
                <div class="filter-group">
                    <label>Estado</label>
                    <select id="statusSelect" class="filter-select">
                        <option value="">Todos</option>
                        <option value="pending">🕐 Pendiente</option>
                        <option value="approved">✅ Aprobado</option>
                        <option value="shipped">🚚 Enviado</option>
                        <option value="delivered">📬 Entregado</option>
                        <option value="cancelled">❌ Cancelado</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>Ordenar por</label>
                    <select id="sortSelect" class="filter-select">
                        <option value="newest">Más reciente</option>
                        <option value="oldest">Más antiguo</option>
                        <option value="highest">Mayor total</option>
                        <option value="lowest">Menor total</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>&nbsp;</label>
                    <button id="refreshBtn" class="add-product-btn">
                        <span>↻</span> Actualizar
                    </button>
                </div>
            </div>
        </div>

        <!-- Contenedor de ventas -->
        <div id="salesContainer"></div>

        <!-- Paginación -->
        <div id="paginationContainer" class="pagination-container" style="display:none;">
            <ul class="pagination" id="paginationList"></ul>
        </div>

    </div>


    <!-- Error message -->
    <div id="errorMessage" class="error-message">
        <strong>Error:</strong> <span id="errorText"></span>
    </div>

<script src="../../js/sales.js"></script>
