<link rel="stylesheet" href="../../css/style.css">

<style>
    @keyframes floatUp {
        from { opacity: 0; transform: translateY(30px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes shimmer {
        0%   { background-position: -200% center; }
        100% { background-position:  200% center; }
    }
    @keyframes pulse-ring {
        0%   { transform: scale(1);    opacity: 0.6; }
        100% { transform: scale(1.35); opacity: 0;   }
    }

    .upgrade-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        position: relative;
        overflow: hidden;
    }

    /* Orbes decorativos de fondo */
    .upgrade-page::before,
    .upgrade-page::after {
        content: '';
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.25;
        pointer-events: none;
        z-index: 0;
    }
    .upgrade-page::before {
        width: 520px; height: 520px;
        background: radial-gradient(circle, #f7971e, #ffd200);
        top: -120px; right: -120px;
    }
    .upgrade-page::after {
        width: 400px; height: 400px;
        background: radial-gradient(circle, #2a5298, #1e3c72);
        bottom: -100px; left: -100px;
    }

    /* Botón volver */
    .back-btn-upgrade {
        position: fixed;
        top: 1.5rem;
        left: 1.5rem;
        z-index: 10;
        animation: floatUp 0.4s ease-out both;
    }

    /* Hero badge */
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(247,151,30,0.15);
        border: 1px solid rgba(247,151,30,0.4);
        color: #ffd200;
        padding: 0.4rem 1.1rem;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 1.25rem;
        animation: floatUp 0.5s ease-out 0.1s both;
    }

    /* Título principal */
    .upgrade-title {
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 800;
        color: white;
        text-align: center;
        line-height: 1.15;
        margin: 0 0 0.75rem;
        text-shadow: 0 4px 20px rgba(0,0,0,0.35);
        animation: floatUp 0.5s ease-out 0.2s both;
    }

    .upgrade-title span {
        background: linear-gradient(90deg, #f7971e, #ffd200, #f7971e);
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: shimmer 3s linear infinite;
    }

    /* Subtítulo */
    .upgrade-sub {
        color: rgba(255,255,255,0.65);
        font-size: 1.05rem;
        text-align: center;
        max-width: 480px;
        line-height: 1.6;
        margin: 0 0 2.5rem;
        animation: floatUp 0.5s ease-out 0.3s both;
    }

    /* Tarjeta del formulario */
    .upgrade-card {
        background: rgba(255,255,255,0.13);
        backdrop-filter: blur(22px);
        -webkit-backdrop-filter: blur(22px);
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,0.22);
        padding: 2.5rem;
        width: 100%;
        max-width: 480px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.35);
        position: relative;
        z-index: 1;
        animation: floatUp 0.55s ease-out 0.35s both;
    }

    /* Beneficios */
    .benefits-list {
        list-style: none;
        padding: 0;
        margin: 0 0 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
    }
    .benefits-list li {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: rgba(255,255,255,0.85);
        font-size: 0.95rem;
    }
    .benefit-icon {
        width: 28px; height: 28px;
        background: rgba(247,151,30,0.18);
        border: 1px solid rgba(247,151,30,0.35);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    /* Divisor */
    .upgrade-divider {
        width: 100%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        margin: 0 0 2rem;
    }

    /* Inputs */
    .upgrade-card .form-group {
        margin-bottom: 1.25rem;
    }
    .upgrade-card label {
        display: block;
        color: rgba(255,255,255,0.8);
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.4px;
        margin-bottom: 0.45rem;
        text-transform: uppercase;
    }
    .upgrade-card input,
    .upgrade-card textarea {
        width: 100%;
        padding: 0.8rem 1.1rem;
        border: 1px solid rgba(255,255,255,0.25);
        border-radius: 14px;
        background: rgba(255,255,255,0.09);
        color: white;
        font-size: 1rem;
        font-family: inherit;
        transition: all 0.3s ease;
        box-sizing: border-box;
        resize: none;
    }
    .upgrade-card input::placeholder,
    .upgrade-card textarea::placeholder {
        color: rgba(255,255,255,0.35);
    }
    .upgrade-card input:focus,
    .upgrade-card textarea:focus {
        outline: none;
        border-color: rgba(247,151,30,0.6);
        background: rgba(255,255,255,0.13);
        box-shadow: 0 0 0 3px rgba(247,151,30,0.12);
    }

    /* Error */
    #upgradeError {
        display: none;
        color: #ff6b6b;
        font-size: 0.88rem;
        text-align: center;
        margin-bottom: 1rem;
        background: rgba(255,107,107,0.1);
        border: 1px solid rgba(255,107,107,0.25);
        border-radius: 10px;
        padding: 0.6rem 1rem;
    }

    /* Botón de envío */
    .upgrade-submit-wrap {
        position: relative;
        display: flex;
        justify-content: center;
    }
    .pulse-ring {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 100%; height: 50px;
        border-radius: 30px;
        border: 2px solid rgba(247,151,30,0.5);
        animation: pulse-ring 1.8s ease-out infinite;
        pointer-events: none;
    }
    #upgradeBtn {
        position: relative;
        width: 100%;
        background: linear-gradient(45deg, #f7971e, #ffd200);
        color: #1a1a1a;
        font-weight: 800;
        font-size: 1.05rem;
        padding: 0.9rem 2rem;
        border: none;
        border-radius: 30px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 6px 25px rgba(247,151,30,0.45);
        letter-spacing: 0.3px;
    }
    #upgradeBtn:hover:not(:disabled) {
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(247,151,30,0.6);
    }
    #upgradeBtn:disabled {
        opacity: 0.65;
        cursor: default;
        transform: none;
    }

    /* Toast de éxito */
    #upgradeSuccess {
        display: none;
        position: fixed;
        top: 1.5rem; left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(45deg, #28a745, #20c997);
        color: white;
        padding: 1rem 2rem;
        border-radius: 15px;
        font-weight: 600;
        box-shadow: 0 8px 30px rgba(40,167,69,0.45);
        z-index: 9999;
        animation: floatUp 0.3s ease-out both;
        white-space: nowrap;
    }
</style>

{{!-- Toast éxito --}}
<div id="upgradeSuccess">✓ ¡Tu tienda fue creada exitosamente!</div>

{{!-- Botón volver --}}
<div class="back-btn-upgrade">
    <a class="back-button" href="/users/profile">← Volver al perfil</a>
</div>

<div class="upgrade-page">

    {{!-- Hero --}}
    <div class="hero-badge">⭐ Cuenta Premium</div>
    <h1 class="upgrade-title">
        Vendé tus productos<br><span>en tu propia tienda</span>
    </h1>
    <p class="upgrade-sub">
        Creá tu tienda en segundos y empezá a publicar productos al instante.
        Sin comisiones ocultas, sin burocracia.
    </p>

    {{!-- Card --}}
    <div class="upgrade-card">

        {{!-- Beneficios --}}
        <ul class="benefits-list">
            <li>
                <div class="benefit-icon">🏪</div>
                Tu propia tienda con nombre y descripción
            </li>
            <li>
                <div class="benefit-icon">📦</div>
                Publicá y gestioná todos tus productos
            </li>
            <li>
                <div class="benefit-icon">⚡</div>
                Activación inmediata, sin aprobaciones
            </li>
        </ul>

        <div class="upgrade-divider"></div>

        {{!-- Form --}}
        <div class="form-group">
            <label>Nombre de tu tienda</label>
            <input id="storeName" type="text" placeholder="Ej: RX Store" maxlength="80"/>
        </div>
        <div class="form-group">
            <label>Descripción</label>
            <textarea id="storeDesc" rows="3" placeholder="Contá de qué trata tu tienda..." maxlength="300"></textarea>
        </div>

        <div id="upgradeError"></div>

        <div class="upgrade-submit-wrap">
            <div class="pulse-ring"></div>
            <button id="upgradeBtn">⭐ Crear mi tienda y ser Premium</button>
        </div>
    </div>

</div>

<script>
    document.getElementById('upgradeBtn').addEventListener('click', async () => {
        const name = document.getElementById('storeName').value.trim();
        const description = document.getElementById('storeDesc').value.trim();
        const errorDiv = document.getElementById('upgradeError');

        errorDiv.style.display = 'none';

        if (!name) {
            errorDiv.textContent = 'El nombre de la tienda es obligatorio.';
            errorDiv.style.display = 'block';
            return;
        }
        if (!description) {
            errorDiv.textContent = 'Agregá una descripción para tu tienda.';
            errorDiv.style.display = 'block';
            return;
        }

        const btn = document.getElementById('upgradeBtn');
        btn.disabled = true;
        btn.textContent = 'Creando tu tienda...';

        try {
            const res = await fetch('http://localhost:8080/api/users/upgrade', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, description })
            });

            if (!res.ok) {
                const data = await res.json().catch(() => ({}));
                throw new Error(data.message || 'Error al crear la tienda');
            }

            const toast = document.getElementById('upgradeSuccess');
            toast.style.display = 'block';

            setTimeout(() => { window.location.href = '/users/profile'; }, 2000);

        } catch (err) {
            errorDiv.textContent = err.message || 'Hubo un error. Intentá de nuevo.';
            errorDiv.style.display = 'block';
            btn.disabled = false;
            btn.textContent = '⭐ Crear mi tienda y ser Premium';
        }
    });
</script>